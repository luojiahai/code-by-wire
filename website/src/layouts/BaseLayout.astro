---
// website/src/layouts/BaseLayout.astro
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const base = import.meta.env.BASE_URL;
const pageUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(`${base}og.png`, Astro.site).href;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="dark" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Code-by-wire" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Code-by-wire: pilot coding agents from one cockpit." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
    <Analytics />
  </head>
  <body>
    <Nav transition:persist />
    <slot />
    <Footer transition:persist />
  </body>
</html>
