---
// website/src/pages/sponsor.astro
import NarrowLayout from '../layouts/NarrowLayout.astro';
---
<NarrowLayout title="Sponsor · Code-by-wire" description="Support Code-by-wire development.">
  <h1>Sponsor</h1>
  <p class="lead">
    Code-by-wire is a personal project, built and maintained in spare time. If it's useful to
    you, here's how to support it.
  </p>
  <div class="sponsor-links">
    <a href="https://github.com/sponsors/luojiahai" class="sponsor-card">
      <span class="sponsor-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7.5-4.35-10-9.1C.6 8.7 2.4 5 6 5c2 0 3.3 1 4 2.3C10.7 6 12 5 14 5c3.6 0 5.4 3.7 4 6.9-2.5 4.75-10 9.1-10 9.1z"/></svg>
      </span>
      <span>
        <strong>GitHub Sponsors</strong>
        <span class="sponsor-desc">Recurring or one-time, through GitHub.</span>
      </span>
    </a>
    <a href="https://buymeacoffee.com/luojiahai" class="sponsor-card">
      <span class="sponsor-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h13v6a5 5 0 0 1-5 5H9a5 5 0 0 1-5-5V8z"/><path d="M17 9.5h1.5a2.5 2.5 0 0 1 0 5H17"/><path d="M8 3v2"/><path d="M12 3v2"/></svg>
      </span>
      <span>
        <strong>Buy Me a Coffee</strong>
        <span class="sponsor-desc">A one-off way to say thanks.</span>
      </span>
    </a>
  </div>
</NarrowLayout>

<style>
  h1 {
    font-weight: 600;
    font-size: 40px;
    margin-bottom: 24px;
  }
  .lead {
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 48px;
  }
  .sponsor-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sponsor-card {
    display: flex;
    align-items: center;
    gap: 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
  }
  .sponsor-card:hover {
    border-color: var(--border-strong);
  }
  .sponsor-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-dim);
  }
  .sponsor-card strong {
    display: block;
    font-size: 16px;
    margin-bottom: 4px;
  }
  .sponsor-desc {
    color: var(--text-dim);
    font-size: 14px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 32px;
    }
    .sponsor-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
